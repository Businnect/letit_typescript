{
  "name": "letit",
  "version": "0.0.0",
  "description": "A professional TypeScript client for the LetIt API, featuring high-performance support for Microposts and Job management.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "npm run test:live",
    "test:live": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\""
  },
  "keywords": [
    "typescript",
    "library",
    "sdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://letit.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Businnect/letit_typescript"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}